# ── Copy to .env and fill in values ──────────────────────────────────────────

# "dev" or "prod"
ENV=dev

# API identity
API_TITLE=My Data API
API_VERSION=1.0.0

# ⚠️  Change this before deploying!
API_PASSWORD=changeme

# SQLite path – local dev
DATABASE_URL=sqlite:///./app.db

# SQLite path – AWS (EC2 / EFS example)
# DATABASE_URL=sqlite:////mnt/efs/data/app.db

# Comma-separated allowed CORS origins
# Use ["*"] in dev; restrict in prod
CORS_ORIGINS=["*"]

# Show Swagger UI /docs and /redoc (true | false)
SHOW_DOCS=true

# Pagination
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=1000

# Server
HOST=0.0.0.0
PORT=5000
